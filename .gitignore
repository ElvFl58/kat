# build output
dist/

# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/


<main class="min-h-screen w-full bg-gradient-to-br from-purple-900 via-purple-800 to-purple-700 flex items-center justify-center p-4 relative overflow-hidden">
  <!-- Efectos de partículas -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <!-- Estrellas centelleantes -->
    <div class="absolute inset-0 star-field opacity-60"></div>
    
    <!-- Brillo suave -->
    <div class="absolute inset-0 bg-radial-gradient from-purple-500/10 via-transparent to-transparent"></div>
  </div>

  <!-- Contenido principal -->
  <section class="relative z-10 max-w-4xl w-full bg-purple-800/70 backdrop-blur-xl rounded-3xl shadow-[0_0_40px_rgba(192,132,252,0.3)] border-2 border-purple-400/30 p-8 md:p-12 text-center transform transition-all duration-500 hover:shadow-[0_0_60px_rgba(236,72,153,0.4)] hover:border-purple-300/50">
    <!-- Título con efecto máquina de escribir -->
    <h1 id="main-title" class="text-4xl md:text-6xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-pink-300 to-purple-200 mb-10 tracking-wide typewriter">
      {reveal.oneWeek ? 'Algo mágico se acerca...' : 'Próximamente...'}
    </h1>

    <!-- Contador regresivo con animaciones mejoradas -->
    <div class="grid grid-cols-4 gap-4 md:gap-6 mb-12">
      <div class="countdown-card animate-float" style="--delay: 0s">
        <div id="dias" class="countdown-number animate-pop-in">{daysLeft}</div>
        <div class="countdown-label">DÍAS</div>
      </div>
      <div class="countdown-card animate-float" style="--delay: 0.2s">
        <div id="horas" class="countdown-number animate-pop-in" style="--delay: 0.1s">{String(hoursLeft).padStart(2, '0')}</div>
        <div class="countdown-label">HORAS</div>
      </div>
      <div class="countdown-card animate-float" style="--delay: 0.4s">
        <div id="minutos" class="countdown-number animate-pop-in" style="--delay: 0.2s">{String(minsLeft).padStart(2, '0')}</div>
        <div class="countdown-label">MIN</div>
      </div>
      <div class="countdown-card animate-float" style="--delay: 0.6s">
        <div id="segundos" class="countdown-number animate-pop-in" style="--delay: 0.3s">{String(secsLeft).padStart(2, '0')}</div>
        <div class="countdown-label">SEG</div>
      </div>
    </div>

    <!-- Mensajes reveladores con efectos -->
    <div class="space-y-6 max-w-2xl mx-auto">
      {reveal.threeWeeks && (
        <p class="text-pink-200/90 text-lg md:text-xl font-medium animate-text-reveal">
          <span class="inline-block animate-float" style="--delay: 0s">✨</span> 
          El tiempo vuela cuando esperas algo hermoso
          <span class="inline-block animate-float" style="--delay: 0.3s">✨</span>
        </p>
      )}
      
      {reveal.twoWeeks && (
        <p class="text-pink-200 text-lg md:text-xl font-medium animate-text-reveal">
          Cada día acerca un momento especial...
        </p>
      )}
      
      {reveal.oneWeek && (
        <div class="bg-gradient-to-r from-purple-600/30 to-pink-500/30 rounded-xl p-4 border border-pink-300/30 animate-glow">
          <p class="text-pink-100 text-xl md:text-2xl font-semibold">
            ¿Puedes sentir la magia en el aire?
          </p>
        </div>
      )}
      
      {reveal.fiveDays && (
        <div class="animate-pulse-slow">
          <p class="text-white text-2xl font-bold">
            <span class="animate-sparkle">✨</span> Pronto será tu día <span class="animate-sparkle">✨</span>
          </p>
        </div>
      )}
      
      {reveal.threeDays && (
        <div class="bg-gradient-to-r from-purple-500 to-pink-500 rounded-xl p-5 shadow-lg animate-glow-fast">
          <p class="text-white text-2xl font-bold">
            ¡El momento está muy cerca!
          </p>
        </div>
      )}
      
      {reveal.twoDays && (
        <div class="animate-bounce-in">
          <p class="text-pink-200 text-3xl font-bold">
            💜 Prepárate 💜
          </p>
        </div>
      )}
      
      {reveal.oneDay && (
        <div class="bg-gradient-to-r from-purple-400 to-pink-400 rounded-xl p-6 shadow-xl animate-pulse-intense">
          <p class="text-white text-3xl font-extrabold tracking-wide">
            ¡MAÑANA ES EL GRAN DÍA!
          </p>
        </div>
      )}
    </div>

    <!-- Elementos decorativos animados -->
    <div class="absolute -z-10 inset-0 overflow-hidden pointer-events-none">
      <!-- Corazones flotantes -->
      {reveal.threeWeeks && (
        <div class="floating-hearts"></div>
      )}
      
      <!-- Confeti sutil -->
      {reveal.twoWeeks && (
        <div class="subtle-confetti"></div>
      )}
      
      <!-- Efecto de burbujas -->
      {reveal.oneWeek && (
        <div class="floating-bubbles"></div>
      )}
    </div>
  </section>
</main>
---
import Layout from '../layouts/Layout.astro';

// Configuración
const birthday = new Date(new Date().getFullYear(), 6, 25); // 30 de agosto
const now = new Date();
let diff = birthday.getTime() - now.getTime();

if (diff < 0) {
  birthday.setFullYear(birthday.getFullYear() + 1);
  diff = birthday.getTime() - now.getTime();
}

const daysLeft = Math.floor(diff / (1000 * 60 * 60 * 24));
const hoursLeft = Math.floor((diff / (1000 * 60 * 60)) % 24);
const minsLeft = Math.floor((diff / (1000 * 60)) % 60);
const secsLeft = Math.floor((diff / 1000) % 60);

// Niveles de revelación
const reveal = {
  threeWeeks: daysLeft <= 21,
  twoWeeks: daysLeft <= 14,
  oneWeek: daysLeft <= 7,
  fiveDays: daysLeft <= 5,
  threeDays: daysLeft <= 3,
  twoDays: daysLeft <= 2,
  oneDay: daysLeft <= 1,
  isToday: now.getDate() === 30 && now.getMonth() === 7
};
---

<Layout>


<style is:global>
  /* Animaciones personalizadas */
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(3deg); }
  }
  
  @keyframes popIn {
    0% { transform: scale(0.8); opacity: 0; }
    80% { transform: scale(1.1); }
    100% { transform: scale(1); opacity: 1; }
  }
  
  @keyframes textReveal {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  @keyframes glow {
    0%, 100% { box-shadow: 0 0 15px rgba(236, 72, 153, 0.3); }
    50% { box-shadow: 0 0 30px rgba(236, 72, 153, 0.6); }
  }
  
  @keyframes glowFast {
    0%, 100% { box-shadow: 0 0 20px rgba(217, 70, 239, 0.5); }
    50% { box-shadow: 0 0 40px rgba(217, 70, 239, 0.8); }
  }
  
  @keyframes pulseSlow {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.05); opacity: 0.9; }
  }
  
  @keyframes pulseIntense {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.08); opacity: 0.8; }
  }
  
  @keyframes sparkle {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.3); }
  }
  
  @keyframes bounceIn {
    0% { transform: scale(0.8); opacity: 0; }
    60% { transform: scale(1.15); }
    80% { transform: scale(0.95); }
    100% { transform: scale(1); opacity: 1; }
  }
  
  @keyframes typewriter {
    from { width: 0; }
    to { width: 100%; }
  }
  
  @keyframes blinkCursor {
    from, to { border-color: transparent; }
    50% { border-color: #f9a8d4; }
  }
  
  @keyframes starTwinkle {
    0%, 100% { opacity: 0.3; transform: scale(0.9); }
    50% { opacity: 1; transform: scale(1.1); }
  }
  
  /* Estilos de componentes */
  .countdown-card {
    background: rgba(107, 33, 168, 0.4);
    backdrop-filter: blur(8px);
    border-radius: 16px;
    padding: 1.5rem 1rem;
    border: 1px solid rgba(216, 180, 254, 0.2);
    box-shadow: 0 8px 32px rgba(167, 139, 250, 0.15);
    animation: float 4s ease-in-out infinite;
    animation-delay: var(--delay);
    transition: all 0.3s ease;
  }
  
  .countdown-card:hover {
    transform: translateY(-8px) !important;
    box-shadow: 0 12px 40px rgba(217, 70, 239, 0.3);
    background: rgba(126, 34, 206, 0.5);
  }
  
  .countdown-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: white;
    margin-bottom: 0.5rem;
    text-shadow: 0 2px 10px rgba(244, 114, 182, 0.7);
  }
  
  .countdown-label {
    font-size: 0.9rem;
    color: #f9a8d4;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
  
  .animate-float {
    animation: float 5s ease-in-out infinite;
    animation-delay: var(--delay);
  }
  
  .animate-pop-in {
    animation: popIn 0.6s cubic-bezier(0.68, -0.55, 0.27, 1.55) forwards;
    animation-delay: var(--delay);
  }
  
  .animate-text-reveal {
    animation: textReveal 1s ease-out forwards;
  }
  
  .animate-glow {
    animation: glow 3s ease-in-out infinite;
  }
  
  .animate-glow-fast {
    animation: glowFast 1.5s ease-in-out infinite;
  }
  
  .animate-pulse-slow {
    animation: pulseSlow 4s ease-in-out infinite;
  }
  
  .animate-pulse-intense {
    animation: pulseIntense 1s ease-in-out infinite;
  }
  
  .animate-sparkle {
    animation: sparkle 1.5s ease-in-out infinite;
    display: inline-block;
  }
  
  .animate-bounce-in {
    animation: bounceIn 0.8s cubic-bezier(0.68, -0.55, 0.27, 1.55);
  }
  
  .typewriter {
    overflow: hidden;
    white-space: nowrap;
    border-right: 3px solid;
    animation: typewriter 2s steps(20) 1s 1 normal both,
               blinkCursor 0.75s step-end infinite;
  }
  
  .star-field {
    background-image: 
      radial-gradient(1px 1px at 20px 30px, white, rgba(0,0,0,0)),
      radial-gradient(1px 1px at 40px 70px, white, rgba(0,0,0,0)),
      radial-gradient(1px 1px at 80px 40px, white, rgba(0,0,0,0)),
      radial-gradient(1px 1px at 120px 90px, white, rgba(0,0,0,0));
    background-size: 150px 150px;
    animation: starTwinkle 3s infinite alternate;
  }
  
  .floating-hearts::before {
    content: "💜";
  position: absolute;
    font-size: 2rem;
    animation: float 6s ease-in-out infinite;
    opacity: 0.3;
  }
  
  /* Generar múltiples corazones con posiciones y delays aleatorios */
  .floating-hearts::before {
    left: 20%;
    top: 10%;
    animation-delay: 0s;
  }
  
  /* Puedes añadir más pseudo-elementos o usar JS para más elementos */
  
  .subtle-confetti {
    background-image: 
      repeating-linear-gradient(45deg, 
        transparent, 
        transparent 25px, 
        rgba(244, 114, 182, 0.1) 25px, 
        rgba(244, 114, 182, 0.1) 50px);
    animation: confettiMove 20s linear infinite;
  }
  
  @keyframes confettiMove {
    from { background-position: 0 0; }
    to { background-position: 100px 100px; }
  }
  
  .floating-bubbles::before {
    content: "";
    position: absolute;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(244, 114, 182, 0.3);
    animation: float 8s ease-in-out infinite;
}
</style>

<script is:inline>
  // Redirección si es hoy
  if (new Date().getDate() === 30 && new Date().getMonth() === 7) {
      window.location.href = '/sorpresa';
  }

  // Actualizar contador en tiempo real
  function updateCountdown() {
    const now = new Date();
    const birthday = new Date(now.getFullYear(), 7, 30);
    let diff = birthday.getTime() - now.getTime();
    
    if (diff < 0) {
      birthday.setFullYear(birthday.getFullYear() + 1);
      diff = birthday.getTime() - now.getTime();
    }
    
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
    const mins = Math.floor((diff / (1000 * 60)) % 60);
    const secs = Math.floor((diff / 1000) % 60);
    
    // Actualizar con animación
    animateNumberChange('dias', days);
    animateNumberChange('horas', String(hours).padStart(2, '0'));
    animateNumberChange('minutos', String(mins).padStart(2, '0'));
    animateNumberChange('segundos', String(secs).padStart(2, '0'));
  }

  // Animación al cambiar números
  function animateNumberChange(id, newValue) {
    const element = document.getElementById(id);
    if (element.textContent !== newValue) {
      element.classList.add('animate-pop-out');
      setTimeout(() => {
        element.textContent = newValue;
        element.classList.remove('animate-pop-out');
        element.classList.add('animate-pop-in');
        setTimeout(() => element.classList.remove('animate-pop-in'), 600);
      }, 300);
    }
  }

  // Iniciar
  updateCountdown();
  setInterval(updateCountdown, 1000);

  // Efecto máquina de escribir para el título
  document.addEventListener('DOMContentLoaded', () => {
    const title = document.getElementById('main-title');
    const text = title.textContent;
    title.textContent = '';
    
    let i = 0;
    function typeWriter() {
      if (i < text.length) {
        title.textContent += text.charAt(i);
        i++;
        setTimeout(typeWriter, 100);
      } else {
        title.classList.add('typewriter-done');
      }
    }
    
    setTimeout(typeWriter, 500);
  });

  // Generar corazones flotantes dinámicamente
  function createFloatingHearts() {
    const container = document.querySelector('.floating-hearts');
    if (!container || !reveal.threeWeeks) return;
    
    const heart = document.createElement('div');
    heart.innerHTML = '💜';
    heart.className = 'absolute text-purple-300 text-xl opacity-30';
    heart.style.left = Math.random() * 100 + '%';
    heart.style.top = Math.random() * 100 + '%';
    heart.style.animation = `float ${6 + Math.random() * 4}s ease-in-out infinite`;
    heart.style.animationDelay = `${Math.random() * 5}s`;
    
    container.appendChild(heart);
    setTimeout(() => heart.remove(), 10000);
  }

  // Generar burbujas flotantes
  function createFloatingBubbles() {
    const container = document.querySelector('.floating-bubbles');
    if (!container || !reveal.oneWeek) return;
    
    const bubble = document.createElement('div');
    bubble.className = 'absolute rounded-full bg-white/5 border border-pink-300/20';
    bubble.style.width = `${Math.random() * 20 + 10}px`;
    bubble.style.height = bubble.style.width;
    bubble.style.left = Math.random() * 100 + '%';
    bubble.style.top = '100%';
    bubble.style.animation = `float ${8 + Math.random() * 6}s ease-in-out infinite`;
    bubble.style.animationDelay = `${Math.random() * 3}s`;
    
    container.appendChild(bubble);
    setTimeout(() => bubble.remove(), 15000);
  }

  // Iniciar efectos
  if (reveal.threeWeeks) setInterval(createFloatingHearts, 800);
  if (reveal.oneWeek) setInterval(createFloatingBubbles, 1200);
</script>
</Layout>