<style>
        section {
            margin: 0;
            background: linear-gradient(to bottom, #ffebee, #f8bbd0, #fcd4e6, #f48fb1, #e91e63);
            color: #d81b60;
            /* overflow: hidden; */
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            text-align: center;
        }

        h1 {
            display: none;
            /* El h1 está presente pero visualmente oculto */
        }

        .heart-animation-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: -1;
        }

        .animated-heart {
            font-size: 25vw;
            /* Corazón gigante */
            color: #f48fb1;
            opacity: 0.7;
            animation: pulseHeart 1.5s infinite alternate;
        }

        @keyframes pulseHeart {
            0% {
                transform: scale(0.9);
            }

            100% {
                transform: scale(1.1);
            }
        }

        .te-amo-sho {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-family: 'Caveat', cursive;
            font-size: 8vw;
            color: #e91e63;
            text-shadow: 2px 2px 4px rgba(255, 182, 193, 0.8);
            opacity: 0;
            animation: appearTeAmoSho 6s infinite;
        }

        @keyframes appearTeAmoSho {

            0%,
            80% {
                opacity: 0;
            }

            90% {
                opacity: 1;
            }

            100% {
                opacity: 0;
            }
        }

        .falling-hearts-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -2;
        }

        .falling-heart {
            position: absolute;
            font-size: 1.8em;
            color: #f06292;
            animation: fallingHearts 7s linear infinite;
            opacity: 0.6;
        }

        @keyframes fallingHearts {
            0% {
                top: -10%;
                left: calc(random(5%, 95%));
                transform: scale(0.7) rotate(45deg);
                opacity: 0.6;
            }

            100% {
                top: 110%;
                left: calc(random(5%, 95%));
                transform: scale(1.1) rotate(-45deg);
                opacity: 0;
            }
        }

        .footer-love {
            position: absolute;
            bottom: 40px;
            width: 100%;
            text-align: center;
            color: #e28;
            text-shadow: 1px 2px 4px #f01;
            font-size: 1.2em;
            font-style: italic;
            font-size: 4rem;
        }
    </style>
   <section>
     <h1>Para Mi Amada Sho</h1>
    <div class="heart-animation-container">
        <div class="animated-heart">❤️</div>
    </div>
    <div class="te-amo-sho">Te Amo Sho</div>
    <div class="falling-hearts-container" id="fallingHearts">
    </div>
      <div class="footer-love">
        Un amor que late eternamente por ti. 💕
    </div>
   </section>

  

    <script type="text/javascript">
        const fallingHeartsContainer = document.getElementById('fallingHearts');
        const numHearts = 20;
        for (let i = 0; i < numHearts; i++) {
            const heart = document.createElement('div');
            heart.classList.add('falling-heart');
            heart.innerText = '💖';
            heart.style.left = `${Math.random() * 100}vw`;
            heart.style.animationDelay = `${Math.random() * 6}s`;
            fallingHeartsContainer.appendChild(heart);
        }
    </script>
