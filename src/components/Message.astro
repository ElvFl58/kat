---

import Layout from "../layouts/Layout.astro";

const mensajes = [
  {
    fecha: "2024-06-01",
    texto: "Cada día contigo es un regalo. Te amo más de lo que imaginas.",
  },
  {
    fecha: "2024-06-02",
    texto: "Tu sonrisa ilumina mis días, gracias por existir.",
  },
  {
    fecha: "2024-06-03",
    texto: "Eres mi pensamiento favorito cada mañana y cada noche.",
  },
  {
    fecha: "2024-06-03",
    texto: "Eres la mas hermosa.",
  },
  // ...puedes agregar más mensajes aquí...
];

const mensajeCentral =
  mensajes[Math.floor(Math.random() * mensajes.length)].texto;
---




  <main
    class="relative min-h-screen flex flex-col items-center justify-center overflow-hidde w-[100%]"
  >
    <main class="m-5">
      {/* Fondo de corazones decorativos y marco rectangular */}
      <div class="absolute inset-0 z-0 m-5">
        <svg
          width="100%"
          height="100%"
          viewBox="0 0 900 700"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          class="w-full h-full"
        >
          {/* Marco rectangular con sombra y animación */}
          <rect
            x="120"
            y="90"
            width="660"
            height="500"
            rx="18"
            fill="none"
            stroke="#e75480"
            stroke-width="8"
            filter="url(#shadow)"
            class="animate-marco"></rect>
          <defs>
            <filter id="shadow" x="0" y="0" width="1000" height="800">
              <feDropShadow
                dx="0"
                dy="6"
                stdDeviation="8"
                flood-color="#e75480"
                flood-opacity="0.18"></feDropShadow>
            </filter>
          </defs>
          {/* Corazones grandes con animación */}
          <g>
            <text
              x="140"
              y="170"
              font-size="90"
              fill="#be185d"
              opacity="0.95"
              class="animate-heart">❤</text
            >
            <text x="210" y="120" font-size="50" fill="#fff" opacity="0.95"
              >❤</text
            >
            <text x="90" y="320" font-size="70" fill="#be185d" opacity="0.95"
              >❤</text
            >
            <text
              x="180"
              y="600"
              font-size="80"
              fill="#fff"
              opacity="0.95"
              class="animate-heart">❤</text
            >
            <text x="90" y="600" font-size="60" fill="#be185d" opacity="0.95"
              >❤</text
            >
            <text
              x="700"
              y="170"
              font-size="90"
              fill="#be185d"
              opacity="0.95"
              class="animate-heart">❤</text
            >
            <text x="800" y="120" font-size="50" fill="#fff" opacity="0.95"
              >❤</text
            >
            <text x="780" y="320" font-size="70" fill="#be185d" opacity="0.95"
              >❤</text
            >
            <text
              x="700"
              y="600"
              font-size="80"
              fill="#fff"
              opacity="0.95"
              class="animate-heart">❤</text
            >
            <text x="800" y="600" font-size="60" fill="#be185d" opacity="0.95"
              >❤</text
            >
          </g>
          {/* Corazones medianos y pequeños */}
          <g>
            <text x="120" y="250" font-size="32" fill="#be185d" opacity="0.85"
              >❤</text
            >
            <text x="180" y="200" font-size="24" fill="#fff" opacity="0.85"
              >❤</text
            >
            <text x="160" y="350" font-size="28" fill="#fff" opacity="0.85"
              >❤</text
            >
            <text x="220" y="650" font-size="32" fill="#be185d" opacity="0.85"
              >❤</text
            >
            <text x="760" y="250" font-size="32" fill="#be185d" opacity="0.85"
              >❤</text
            >
            <text x="800" y="200" font-size="24" fill="#fff" opacity="0.85"
              >❤</text
            >
            <text x="780" y="350" font-size="28" fill="#fff" opacity="0.85"
              >❤</text
            >
            <text x="720" y="650" font-size="32" fill="#be185d" opacity="0.85"
              >❤</text
            >
          </g>
          {/* Puntos decorativos con animación */}
          <g>
            <circle
              cx="110"
              cy="100"
              r="6"
              fill="#be185d"
              opacity="0.7"
              class="animate-dot"></circle>
            <circle cx="180" cy="80" r="4" fill="#be185d" opacity="0.7"
            ></circle>
            <circle
              cx="850"
              cy="100"
              r="6"
              fill="#be185d"
              opacity="0.7"
              class="animate-dot"></circle>
            <circle cx="780" cy="80" r="4" fill="#be185d" opacity="0.7"
            ></circle>
            <circle
              cx="120"
              cy="650"
              r="6"
              fill="#be185d"
              opacity="0.7"
              class="animate-dot"></circle>
            <circle cx="180" cy="670" r="4" fill="#be185d" opacity="0.7"
            ></circle>
            <circle
              cx="850"
              cy="650"
              r="6"
              fill="#be185d"
              opacity="0.7"
              class="animate-dot"></circle>
            <circle cx="780" cy="670" r="4" fill="#be185d" opacity="0.7"
            ></circle>
          </g>
        </svg>
      </div>
      {/* Mensaje romántico centrado dentro del marco */}
      <div
        class="absolute left-1/2 top-1/2 z-10"
        style="transform: translate(-50%, -50%)"
      >
        <div
          class="w-[100%] max-w-full min-h-[220px] flex items-center justify-center animate-fadein"
        >
          <span
            class=" max-w-2xl text-wrap text-2xl md:text-3xl font-[Dancing_Script,cursive,sans-serif] text-pink-700 font-bold text-center animate-fadein-text"
            >{mensajeCentral}</span
          >
        </div>
      </div>
      <style>
        .videos {
          z-index: 2;
          position: relative;
          width: 100vw;
          margin-top: 0.1px;
        }
        @keyframes fadein {
          from {
            opacity: 0;
            transform: scale(0.92) translateY(40px);
          }
          to {
            opacity: 1;
            transform: scale(1) translateY(0);
          }
        }
        .animate-fadein {
          animation: fadein 1.2s cubic-bezier(0.4, 0, 0.2, 1) both;
        }
        @keyframes fadeinText {
          from {
            opacity: 0;
            transform: scale(0.95) translateY(30px);
          }
          to {
            opacity: 1;
            transform: scale(1) translateY(0);
          }
        }
        .animate-fadein-text {
          animation: fadeinText 1.5s 0.5s cubic-bezier(0.4, 0, 0.2, 1) both;
        }
        @keyframes heartBeat {
          0%,
          100% {
            transform: scale(1);
          }
          20% {
            transform: scale(1.18);
          }
          40% {
            transform: scale(0.95);
          }
          60% {
            transform: scale(1.08);
          }
          80% {
            transform: scale(1);
          }
        }
        .animate-heart {
          animation: heartBeat 2.2s infinite;
          transform-origin: center;
        }
        @keyframes dotBlink {
          0%,
          100% {
            opacity: 0.7;
            r: 6;
          }
          50% {
            opacity: 1;
            r: 9;
          }
        }
        .animate-dot {
          animation: dotBlink 1.8s infinite;
        }
      </style>
    </main>
  </main>

